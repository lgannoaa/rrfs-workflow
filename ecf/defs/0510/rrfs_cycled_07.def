  family primary
    edit rrfs_ver 'v1.0.0'
    edit PACKAGEHOME '/lfs/h2/emc/global/noscrub/%EMC_USER%/para/packages/rrfs.%rrfs_ver%'
    edit NET 'rrfs'
    edit RUN 'rrfs'
    edit PROJ 'RRFS'
    edit PROJENVIR 'DEV'
    edit MACHINE_SITE 'development' 
    edit ENVIR 'prod'
    edit QUEUE 'devhigh'
    edit QUEUE_ARCH 'dev_transfer'
