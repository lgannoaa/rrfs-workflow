suite nco_rrfs_dev_00
  family primary
    edit rrfs_ver 'v1.0.0'
    edit PACKAGEHOME '/lfs/h2/emc/global/noscrub/%EMC_USER%/para/packages/rrfs.%rrfs_ver%'
    edit NET 'rrfs'
    edit RUN 'rrfs'
    edit PROJ 'RRFS'
    edit PROJENVIR 'DEV'
    edit MACHINE_SITE 'development' 
    edit ENVIR 'prod'
    edit QUEUE 'devhigh'
    edit QUEUE_ARCH 'dev_transfer'
    edit OUTPUTDIR '/lfs/h2/emc/ptmp/%EMC_USER%/ecflow_rrfs/para/output/prod/today'
    family 00
      edit CYC '00'
      task cycle_end
        edit ECF_FILES '%PACKAGEHOME%/ecf/scripts'
        cron 23:00
      family rrfs
