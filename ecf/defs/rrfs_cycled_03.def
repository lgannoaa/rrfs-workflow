          family init
            family det
              task jrrfs_det_smoke
                trigger :TIME >= 0350 and :TIME < 0410  # 20 mins window 
              task jrrfs_det_radarref
                trigger :TIME >= 0345 and :TIME < 0405
              task jrrfs_det_glmfed
                trigger :TIME >= 0345 and :TIME < 0405
              task jrrfs_det_bufr
                trigger :TIME >= 0345 and :TIME < 0405

            endfamily   # det
            family spinup
              task jrrfs_det_smoke_spinup
                trigger :TIME >= 0350 and :TIME < 0410
              task jrrfs_det_radarref_spinup
                trigger :TIME >= 0345 and :TIME < 0405
              task jrrfs_det_glmfed_spinup
                trigger :TIME >= 0345 and :TIME < 0405
